{
  "buildCommand": "vite build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/api/checkin", "destination": "/api/checkin" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/checkin.ts": {
      "includeFiles": "participantes.json"
    }
  }
}
